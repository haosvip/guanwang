{
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node@3.0.2"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1",
      "status": 200
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}